{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --external:electron --outdir=dist/electron --format=esm --packages=external",
    "start": "tsx server.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently \"npm run dev\" \"npm run build:electron -- --watch\" \"wait-on http://localhost:3000 dist/electron/main.js && electron .\"",
    "electron:build": "npm run build && npm run build:electron && electron-builder",
    "mobile:sync": "vite build && cap sync",
    "mobile:open-android": "cap open android",
    "mobile:open-ios": "cap open ios"
  },
  "build": {
    "appId": "com.lumiai.app",
    "productName": "LumiAI",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@base-ui/react": "^1.3.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.49.0",
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "gaxios": "^7.1.4",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "node-fetch-native": "^1.6.7",
    "openai": "^6.34.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.2.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "node-fetch": "npm:node-fetch-native"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/sqlite3": "^3.1.11",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^8.0.8",
    "wait-on": "^9.0.5"
  }
}
