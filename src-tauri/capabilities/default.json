{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Lumi OS default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-open",
    "fs:default",
    "fs:allow-read",
    "dialog:default",
    "dialog:allow-open",
    "os:default",
    "global-shortcut:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "process:default"
  ]
}
