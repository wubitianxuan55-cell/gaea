---
import Base from '../layouts/Base.astro';
---

<Base title="LumiAI - Distributed Intelligence">
  <main class="flex min-h-screen items-center justify-center bg-black text-white">
    <div class="text-center space-y-6 p-8">
      <h1 class="text-6xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-orange-400 to-amber-500">
        LumiAI
      </h1>
      <p class="text-xl text-gray-400 max-w-lg mx-auto">
        Distributed Intelligence Operating System — Your AI companion across desktop, mobile, and web.
      </p>
      <div class="flex gap-4 justify-center mt-8">
        <a href="/download" class="px-6 py-3 bg-orange-500 hover:bg-orange-400 text-black font-semibold rounded-lg transition">
          Download Desktop App
        </a>
        <a href="https://app.lumiai.asia" class="px-6 py-3 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-lg transition">
          Launch Web App
        </a>
      </div>
    </div>
  </main>
</Base>
