---
import Base from '../layouts/Base.astro';
import { translations } from '../i18n/translations';

const url = new URL(Astro.request.url);
const langParam = url.searchParams.get('lang');
const lang: 'en' | 'zh' = langParam === 'zh' ? 'zh' : 'en';
const t = translations[lang];
---

<Base title={t.title} description={t.description} lang={lang}>
  <main class="flex min-h-screen items-center justify-center relative overflow-hidden">
    <!-- Ambient background -->
    <div class="absolute inset-0 z-0 pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-[600px] h-[600px] bg-celestial-saturn/10 blur-[120px] rounded-full" />
      <div class="absolute bottom-1/3 right-1/4 w-[500px] h-[500px] bg-celestial-mars/8 blur-[100px] rounded-full" />
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-celestial-glow/5 blur-[150px] rounded-full" />
    </div>

    <div class="text-center space-y-8 p-8 relative z-10">
      <!-- Floating orb -->
      <div class="relative w-24 h-24 mx-auto mb-4">
        <div class="absolute inset-0 bg-celestial-saturn/30 rounded-full blur-2xl animate-pulse" />
        <div class="relative w-full h-full rounded-full border border-white/10 bg-black/40 backdrop-blur-xl flex items-center justify-center animate-float">
          <div class="w-3 h-3 bg-celestial-saturn rounded-full shadow-[0_0_20px_rgba(255,204,0,0.5)]" />
        </div>
      </div>

      <h1 class="text-7xl md:text-8xl font-black bg-clip-text text-transparent bg-gradient-to-b from-white via-white/90 to-white/30 drop-shadow-2xl">
        {t.heroTitle}
      </h1>
      <p class="text-xl text-white/40 max-w-lg mx-auto italic">
        {t.heroSubtitle}
      </p>
      <div class="flex gap-4 justify-center mt-8 flex-wrap">
        <a
          href="https://app.lumiai.asia"
          class="px-8 py-4 bg-celestial-saturn text-black font-bold rounded-2xl hover:scale-105 active:scale-95 transition-all shadow-[0_0_50px_rgba(255,204,0,0.2)]"
        >
          {t.getStarted}
        </a>
        <a
          href="/download"
          class="px-8 py-4 glass rounded-2xl text-white font-bold hover:bg-white/10 transition-all"
        >
          {t.downloadApp}
        </a>
      </div>

      <!-- Lang switcher -->
      <div class="flex gap-3 justify-center mt-10">
        <a
          href="?lang=en"
          class={`text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full border transition-all ${
            lang === 'en' ? 'bg-white/10 border-white/20 text-white' : 'border-transparent text-white/20 hover:text-white/50'
          }`}
        >
          EN
        </a>
        <a
          href="?lang=zh"
          class={`text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full border transition-all ${
            lang === 'zh' ? 'bg-white/10 border-white/20 text-white' : 'border-transparent text-white/20 hover:text-white/50'
          }`}
        >
          中文
        </a>
      </div>
    </div>
  </main>
</Base>
