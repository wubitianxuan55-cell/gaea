---
import Base from '../layouts/Base.astro';
---

<Base title="Download Lumi OS — LumiAI">
  <main class="flex min-h-screen items-center justify-center bg-black text-white">
    <div class="text-center space-y-6 p-8 max-w-2xl">
      <h1 class="text-4xl font-bold">Download Lumi OS</h1>
      <p class="text-gray-400">Get the latest version from GitHub Releases.</p>
      <div id="download-buttons" class="flex flex-col gap-4 items-center mt-8">
        <div class="flex flex-col gap-4 items-center">
          <div class="w-64 h-12 bg-white/5 rounded-lg animate-pulse"></div>
          <div class="w-64 h-12 bg-white/5 rounded-lg animate-pulse"></div>
        </div>
        <p class="text-sm text-gray-500 mt-4">Loading latest release...</p>
      </div>
    </div>
  </main>
</Base>

<script>
  const API = 'https://api.github.com/repos/maoxiansheng946-dev/-lumi-OS/releases/latest';
  const container = document.getElementById('download-buttons');

  function formatSize(bytes: number): string {
    if (bytes >= 1024 * 1024 * 1024) return (bytes / (1024 * 1024 * 1024)).toFixed(1) + ' GB';
    if (bytes >= 1024 * 1024) return Math.round(bytes / (1024 * 1024)) + ' MB';
    if (bytes >= 1024) return Math.round(bytes / 1024) + ' KB';
    return bytes + ' B';
  }

  function buildButton(label: string, url: string, size: string, primary: boolean) {
    const a = document.createElement('a');
    a.href = url;
    a.className = primary
      ? 'px-6 py-3 bg-orange-500 hover:bg-orange-400 text-black font-semibold rounded-lg transition w-64 block'
      : 'px-6 py-3 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-lg transition w-64 border border-white/20 block';
    a.innerHTML = `${label}<br><span class="text-xs opacity-60">${size}</span>`;
    return a;
  }

  fetch(API)
    .then(res => res.json())
    .then(release => {
      const assets = release.assets || [];
      const exe = assets.find((a: any) => a.name.endsWith('.exe'));
      const deb = assets.find((a: any) => a.name.endsWith('.deb'));
      const appimage = assets.find((a: any) => a.name.endsWith('.AppImage'));

      if (!exe && !deb && !appimage) throw new Error('No assets found');

      container.innerHTML = '';

      const wrapper = document.createElement('div');
      wrapper.className = 'flex flex-col gap-4 items-center';

      if (exe) wrapper.appendChild(buildButton('Download for Windows', exe.browser_download_url, formatSize(exe.size), true));
      if (deb) wrapper.appendChild(buildButton('Download for Linux (.deb)', deb.browser_download_url, formatSize(deb.size), false));
      if (appimage) wrapper.appendChild(buildButton('Download for Linux (.AppImage)', appimage.browser_download_url, formatSize(appimage.size), false));

      container.appendChild(wrapper);

      const version = document.createElement('p');
      version.className = 'text-sm text-gray-500 mt-4';
      version.textContent = `Version ${release.tag_name || 'latest'} — automatic updates included.`;
      container.appendChild(version);
    })
    .catch(() => {
      container.innerHTML = `
        <div class="flex flex-col gap-4 items-center">
          <a href="https://github.com/maoxiansheng946-dev/-lumi-OS/releases/latest"
             class="px-6 py-3 bg-orange-500 hover:bg-orange-400 text-black font-semibold rounded-lg transition w-64">
            Download for Windows
          </a>
          <a href="https://github.com/maoxiansheng946-dev/-lumi-OS/releases/latest"
             class="px-6 py-3 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-lg transition w-64 border border-white/20">
            Download for Linux (.deb / .AppImage)
          </a>
          <p class="text-sm text-gray-500 mt-4">Latest version with automatic updates included.</p>
        </div>
      `;
    });
</script>
