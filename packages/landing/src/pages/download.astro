---
import Base from '../layouts/Base.astro';
---

<Base title="Download Lumi OS — LumiAI">
  <main class="flex min-h-screen items-center justify-center bg-black text-white">
    <div class="text-center space-y-6 p-8 max-w-2xl">
      <h1 class="text-4xl font-bold">Download Lumi OS</h1>
      <p class="text-gray-400">Get the latest version from GitHub Releases.</p>
      <div class="flex flex-col gap-4 items-center mt-8">
        <a href="https://github.com/maoxiansheng946-dev/-lumi-OS/releases/latest/download/Lumi%20OS_2.0.4_x64-setup.exe"
           class="px-6 py-3 bg-orange-500 hover:bg-orange-400 text-black font-semibold rounded-lg transition w-64">
          Download for Windows
        </a>
        <a href="https://github.com/maoxiansheng946-dev/-lumi-OS/releases/latest/download/lumi-os_2.0.4_amd64.deb"
           class="px-6 py-3 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-lg transition w-64 border border-white/20">
          Download for Linux (.deb)
        </a>
        <a href="https://github.com/maoxiansheng946-dev/-lumi-OS/releases/latest/download/lumi-os_2.0.4_amd64.AppImage"
           class="px-6 py-3 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-lg transition w-64 border border-white/20">
          Download for Linux (.AppImage)
        </a>
        <p class="text-sm text-gray-500 mt-4">Latest version with automatic updates included.</p>
      </div>
    </div>
  </main>
</Base>
